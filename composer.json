{
    "name": "tcc-etec/fetel",
    "description": "Plataforma escolar FETEL - Sistema de gestão educacional",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Model\\": "app/Model/",
            "App\\Controller\\": "app/Controller/",
            "App\\View\\": "app/View/",
            "Core\\": "Core/"
        },
        "files": [
            "Config/db/conexao.php",
            "Core/autenticacao.php"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
